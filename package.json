{
  "name": "synthesis-cli",
  "version": "0.4.2",
  "description": "Thin umbrella CLI that installs and routes to protocol child CLIs",
  "private": false,
  "type": "module",
  "bin": {
    "synth": "dist/cli.js",
    "synthesis": "dist/cli.js"
  },
  "files": [
    "dist",
    "skills",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup src/cli.ts --format esm --dts --clean",
    "dev": "tsx src/cli.ts",
    "test": "vitest run --exclude test/smoke.test.ts",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "prepare": "npm run build",
    "test:integration": "vitest run test/smoke.test.ts",
    "test:coverage": "vitest run --coverage --exclude test/smoke.test.ts"
  },
  "keywords": [
    "cli",
    "synthesis",
    "uniswap",
    "lido",
    "moonpay",
    "8004"
  ],
  "author": "",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/winstain/synthesis-cli.git"
  },
  "license": "MIT",
  "engines": {
    "node": ">=20"
  },
  "publishConfig": {
    "provenance": false,
    "access": "public"
  },
  "dependencies": {
    "@moonpay/cli": "^1.6.4",
    "@open-wallet-standard/core": "^0.3.9",
    "8004-cli": "^1.0.2",
    "filecoin-cli": "^1.2.0",
    "lido-cli": "^1.2.0",
    "uniswap-cli": "^1.2.0",
    "viem": "^2.47.5"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "@vitest/coverage-v8": "^2.1.8",
    "tsup": "^8.2.0",
    "tsx": "^4.20.0",
    "typescript": "^5.8.0",
    "vitest": "^2.1.8"
  },
  "optionalDependencies": {
    "utf-8-validate": "^5.0.10"
  }
}
