{
  "name": "synthesis-cli",
  "version": "0.2.1",
  "description": "Thin umbrella CLI that installs and routes to protocol child CLIs",
  "private": false,
  "type": "module",
  "bin": {
    "synth": "dist/cli.js",
    "synthesis": "dist/cli.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup src/cli.ts --format esm --dts --clean",
    "dev": "tsx src/cli.ts",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "prepare": "npm run build"
  },
  "keywords": [
    "cli",
    "synthesis",
    "uniswap",
    "lido",
    "moonpay",
    "8004"
  ],
  "author": "",
  "license": "MIT",
  "engines": {
    "node": ">=20"
  },
  "publishConfig": {
    "provenance": false,
    "access": "public"
  },
  "dependencies": {
    "@moonpay/cli": "^1.6.4",
    "8004-cli": "^1.0.2",
    "filecoin-cli": "^1.0.0",
    "lido-cli": "^1.2.0",
    "uniswap-cli": "^1.2.0"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "tsup": "^8.2.0",
    "tsx": "^4.20.0",
    "typescript": "^5.8.0",
    "vitest": "^2.1.8"
  }
}
