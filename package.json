{
  "name": "synthesis-cli",
  "version": "0.1.0",
  "description": "Thin wrapper CLI that routes to DeFi and infra child CLIs",
  "private": false,
  "type": "module",
  "bin": {
    "synthesis": "dist/cli.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup src/cli.ts --format esm --dts --clean",
    "dev": "tsx src/cli.ts",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "prepare": "npm run build"
  },
  "keywords": [
    "cli",
    "wrapper",
    "uniswap",
    "lido",
    "moonpay",
    "filecoin"
  ],
  "author": "",
  "license": "MIT",
  "engines": {
    "node": ">=20"
  },
  "publishConfig": {
    "provenance": false,
    "access": "public"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "tsup": "^8.2.0",
    "tsx": "^4.20.0",
    "typescript": "^5.8.0",
    "vitest": "^2.1.8"
  }
}
